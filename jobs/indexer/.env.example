# Supabase (same project as the app)
SUPABASE_URL=
# Service role key — server-side only; never ship to clients
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URL for the same DB (service role or postgres user; bypasses RLS)
DATABASE_URL=

# OpenAI embeddings (text-embedding-3-small, 1536 dims — must match migration)
OPENAI_API_KEY=

# Which IPO row to index (uuid from ipos.id)
IPO_ID=

# Storage path inside the prospectus bucket, e.g. dev/sample.pdf
STORAGE_OBJECT_PATH=

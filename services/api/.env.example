# Supabase project URL (no trailing slash), e.g. https://xxxx.supabase.co
# Required for JWT verification via JWKS (ECC / RSA signing — current Supabase default).
SUPABASE_URL=

# Optional: Legacy HS256 shared secret (Settings → JWT Keys → Legacy JWT Secret).
# Use only while old sessions still exist; remove after all tokens use the new key.
SUPABASE_JWT_SECRET=

# Postgres: direct or pooler URI for a DB role that can read/write app tables (bypasses RLS), e.g. postgres user — server-side only
DATABASE_URL=

# Optional until RapidAPI + Upstash are wired
# RAPIDAPI_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

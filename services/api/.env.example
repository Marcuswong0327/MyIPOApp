# Supabase project URL (no trailing slash), e.g. https://xxxx.supabase.co
# Required for JWT verification via JWKS (ECC / RSA signing — current Supabase default).
SUPABASE_URL=

# Optional: Legacy HS256 shared secret (Settings → JWT Keys → Legacy JWT Secret).
# Use only while old sessions still exist; remove after all tokens use the new key.
SUPABASE_JWT_SECRET=

# Postgres: direct or pooler URI for a DB role that can read/write app tables (bypasses RLS), e.g. postgres user — server-side only
DATABASE_URL=

# OpenAI (Auditor v1)
OPENAI_API_KEY=
# Optional override; defaults to gpt-5.4-mini
OPENAI_MODEL=

# RapidAPI + Upstash market context
RAPIDAPI_KEY=
RAPIDAPI_HOST=yahoo-finance-real-time1.p.rapidapi.com
# Optional path overrides if your subscribed endpoint differs:
# RAPIDAPI_BASE_URL=
# RAPIDAPI_QUOTE_PATH=/stock/get-detail
# RAPIDAPI_NEWS_PATH=/stock/get-news
# RAPIDAPI_SEARCH_PATH=/auto-complete
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

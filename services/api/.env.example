# Supabase project URL (no trailing slash), e.g. https://xxxx.supabase.co
# Required for JWT verification via JWKS (ECC / RSA signing — current Supabase default).
SUPABASE_URL=

# Optional: Legacy HS256 shared secret (Settings → JWT Keys → Legacy JWT Secret).
# Use only while old sessions still exist; remove after all tokens use the new key.
SUPABASE_JWT_SECRET=

# Postgres: direct or pooler URI for a DB role that can read/write app tables (bypasses RLS), e.g. postgres user — server-side only
DATABASE_URL=

# OpenAI (Auditor v1)
OPENAI_API_KEY=
# Optional override; defaults to gpt-5.4-mini
OPENAI_MODEL=

# RapidAPI + Upstash (market context + Phase 1 curated routes)
RAPIDAPI_KEY=
# No spaces around = ; must match the host your RapidAPI subscription uses
RAPIDAPI_HOST=yahoo-finance-real-time1.p.rapidapi.com
# Optional overrides if your subscription uses different paths:
# RAPIDAPI_BASE_URL=https://yahoo-finance-real-time1.p.rapidapi.com
# RAPIDAPI_SYMBOL_SEARCH_PATH=/auto-complete
# RAPIDAPI_PUBLIC_SEARCH_PATH=/search
# RAPIDAPI_QUOTE_PATH=/stock/get-detail
# RAPIDAPI_LEGACY_NEWS_PATH=/stock/get-news
# RAPIDAPI_STOCK_SUMMARY_PATH=/stock/get-summary
# RAPIDAPI_STOCK_QUOTE_SUMMARY_PATH=/stock/get-quote-summary
# RAPIDAPI_NEWS_LIST_PATH=/news/get-list
# RAPIDAPI_NEWS_ARTICLE_PATH=/news/get-article
# RAPIDAPI_MARKET_TRENDING_PATH=/market/get-trending-tickers
# RAPIDAPI_MARKET_TICKER_LISTS_PATH=/market/get-ticker-lists
# RAPIDAPI_MARKET_SUMMARY_PATH=/market/get-summary
# RAPIDAPI_MARKET_POPULAR_WATCHLISTS_PATH=/market/get-popular-watchlists
# RAPIDAPI_MARKET_WATCHLIST_PERFORMANCE_PATH=/market/get-watchlist-performance

# Cache TTLs (seconds) for curated routes (Upstash cache-aside)
# CACHE_TTL_SEARCH_SEC=300
# CACHE_TTL_STOCK_SUMMARY_SEC=600
# CACHE_TTL_STOCK_QUOTE_SUMMARY_SEC=300
# CACHE_TTL_NEWS_LIST_SEC=10800
# CACHE_TTL_NEWS_ARTICLE_SEC=3600
# CACHE_TTL_MARKET_TRENDING_SEC=120
# CACHE_TTL_MARKET_TICKER_LISTS_SEC=3600
# CACHE_TTL_MARKET_SUMMARY_SEC=300
# CACHE_TTL_MARKET_POPULAR_WATCHLISTS_SEC=3600
# CACHE_TTL_MARKET_WATCHLIST_PERF_SEC=600

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
